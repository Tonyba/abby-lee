{% stylesheet %}
  .story-carousel-item .inner {
    background-color: #f5f5f5;
    padding: 18px 30px;
  }
{% endstylesheet %}

<div class="embla__item">
  <div class="inner">
    <div class="main-text flex items-center">
      <span class="icon">
        {{ 'quote.svg' | inline_asset_content }}
      </span>
      <div class="text">"{{ block.settings.main_text }}"</div>
    </div>

    <div class="content">
      {{ block.settings.content }}
    </div>

    <div class="author-container">
      <div class="author-name">{{ block.settings.name }}</div>
      <div class="subtext">{{ block.settings.subtext }}</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "story carousel Item",
  "class": "story-carousel-item",
  "settings": [
    {
      "type": "text",
      "id": "main_text",
      "label": "Main Text"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Author"
    },
    {
      "type": "text",
      "id": "name",
      "label": "name"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Position/location"
    }
  ],
  "presets": [
    {
      "name": "story carousel Item"
    }
  ]
}
{% endschema %}
