{% if block.settings.img != blank %}
  {{ block.settings.img | image_url: width: 400, height: 400 | image_tag }}
{% endif %}

{% schema %}
{
  "name": "mega menu item",
  "class": "mega-menu-item",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "mega menu item"
    }
  ]
}
{% endschema %}
