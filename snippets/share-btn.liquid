{% stylesheet %}
  .btn-share {
    position: absolute;
    top: 15px;
    left: 15px;
    z-index: 2;
  }

  .btn-share {
    background-color: white;
    border: 1px solid #d9d9d9;
    color: black;
    border-radius: 3px;
    padding: 9px 14px;
  }
{% endstylesheet %}

