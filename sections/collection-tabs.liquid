{% stylesheet %}
{% endstylesheet %}

<div class="section section section--page-width">
  <div class="heading">{{ section.settings.heading }}</div>

  <div class="collections tabs-container">
    <div class="tabs__list" role="tablist" aria-label="collections">
      {% for collection in section.settings.collection_list %}
        <button
          class="tabs__tab"
          id="{{ collection.handle }}"
          role="tab"
          aria-selected="true"
          aria-controls="panel-{{ forloop.index }}"
        >
          {{ collection.title }}
        </button>
      {% endfor %}
    </div>

    <div class="tabs__panels">
      <div class="tabs__panel" id="panel-1" role="tabpanel" aria-labelledby="tab-1">
        <p>Contenido de la pestaña 1. Aquí va la información correspondiente.</p>
      </div>
      <div class="tabs__panel" id="panel-2" role="tabpanel" aria-labelledby="tab-2" hidden>
        <p>Contenido de la pestaña 2. Otro texto interesante.</p>
      </div>
      <div class="tabs__panel" id="panel-3" role="tabpanel" aria-labelledby="tab-3" hidden>
        <p>Contenido de la pestaña 3. Más detalles aquí.</p>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
<script src="{{ 'mount-embla.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "collection tabs",
  "class": "collection-tabs",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 8
    }
  ],
  "presets": [
    {
      "name": "collections tabs"
    }
  ]
}
{% endschema %}
