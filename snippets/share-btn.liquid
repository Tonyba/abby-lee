    </span>
    Share
  </div>
{% endif %}

<script>
  const shareButton = document.querySelector('.btn-share');
  shareButton.addEventListener('click', async () => {
    if (navigator.share) {
      try {
        await navigator.share({
          title: '{{ product.title }}', // Gets the title of the current page
          text: 'Check out this interesting page!',
          url: '{{ product.url }}', // Gets the current page's URL
        });
        console.log('Content shared successfully!');
        // statusEl.textContent = 'Shared successfully!';
      } catch (error) {
        console.error('Error sharing:', error);
        // statusEl.textContent = 'Error sharing: ' + error.message;
      }
    } else {
      // Fallback for browsers that do not support the Web Share API
      alert('Your browser does not support the Web Share API. You can copy the URL manually.');
      // You can also provide a traditional social media share button UI here as a fallback
    }
  });
</script>
