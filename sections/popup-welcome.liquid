{% stylesheet %}
  /* Estilos del popup (overlay y contenido) */
  .popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .popup-overlay.active {
    visibility: visible;
    opacity: 1;
  }

  .popup-content-custom {
    background-color: white;
    padding-top: 67px;
    padding-left: 52px;
    padding-right: 52px;
    padding-bottom: 77px;
    position: relative;
    max-width: 90%;
    width: 500px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .popup-close {
    position: absolute;
    padding: 0 !important;
    padding-left: 2px !important;
    top: 10px;
    right: 15px;
    font-size: 24px;
    cursor: pointer;
    background: none;
    border: none;
    color: white;
    background-color: black;
    border-radius: 100%;
    width: 40px;
    height: 40px;
  }

  .popup-close:hover {
    color: #333;
  }

  .popup-content-custom ul {
    padding-left: 20px;
    color: #585858;
    margin: 25px 0;
  }

  .popup-content-custom .button {
    width: 100%;
    background-color: black;
    letter-spacing: 5%;
    line-height: 160%;
  }

  .popup-content-custom .button:hover {
    background-color: #fc0102;
  }
{% endstylesheet %}

<div class="hide">
  <div class="popup-content-custom color-scheme-7">
    <button class="popup-close flex items-center justify-center" aria-label="Cerrar popup">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1.44634 17.3562L-1.79549e-05 15.9099L7.23176 8.6781L-1.79549e-05 1.44633L1.44634 -2.84342e-05L8.67811 7.23175L15.9099 -2.77598e-05L17.3562 1.44633L10.1245 8.6781L17.3562 15.9099L15.9099 17.3562L8.67811 10.1245L1.44634 17.3562Z" fill="white"/>
      </svg>
    </button>
    <h2>
      {{ section.settings.title }}
      {{ localization.country }}
    </h2>
    {{ section.settings.content }}

    <a class="button" href="{{ section.settings.btn_link }}">{{ section.settings.btn_text }}</a>
  </div>
</div>

<script defer>
  (function () {
    // Clave para localStorage (evita mostrar el popup nuevamente)
    const POPUP_STORAGE_KEY = 'popup_welcome_shown';

    // Comprobar si ya se mostró este popup
    const hasBeenShown = localStorage.getItem(POPUP_STORAGE_KEY);

    // Si ya se mostró, no hacer nada
    //  if (hasBeenShown) return;

    // Clonar el contenido del popup (que está oculto en .hide)
    const originalContent = document.querySelector('.hide .popup-content-custom');
    if (!originalContent) return;

    // Crear el overlay (fondo oscuro)
    const overlay = document.createElement('div');
    overlay.className = 'popup-overlay';

    // Clonar el contenido para no modificar el original
    const popupContent = originalContent;

    // Añadir botón de cierre (X) al contenido clonado
    const closeButton = document.querySelector('.popup-close');

    // Agregar el contenido al overlay
    overlay.appendChild(popupContent);

    // Agregar el overlay al body
    document.body.appendChild(overlay);

    // Función para cerrar el popup y guardar en localStorage
    function closePopup() {
      overlay.classList.remove('active');
      setTimeout(() => {
        overlay.remove();
      }, 300); // Esperar a que termine la transición
      localStorage.setItem(POPUP_STORAGE_KEY, 'true');
    }

    // Evento para cerrar con el botón X
    closeButton.addEventListener('click', closePopup);

    // Evento para cerrar haciendo clic en el overlay (fondo)
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) {
        closePopup();
      }
    });

    // Mostrar el popup después de un breve retraso (2 segundos)
    setTimeout(() => {
      overlay.classList.add('active');
    }, 2000);
  })();
</script>

{% schema %}
{
  "name": "Popup Welcome",
  "class": "popup-welcome",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Popup Welcome"
    }
  ]
}
{% endschema %}
