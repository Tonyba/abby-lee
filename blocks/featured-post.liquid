{% assign featured_article = null %}

{% for article in blog.articles %}
  {% if article.tags contains 'featured' %}
    {% assign featured_article = article %}
    {% break %}
  {% endif %}
{% endfor %}

{% stylesheet %}
{% endstylesheet %}

{% if featured_article %}
  <div class="featured-post-wrapper">
    {{
      featured_article.image
      | image_url: width: featured_article.image.width, height: featured_article.image.height
      | image_tag
    }}

    <div class="featured-post-content"></div>
  </div>
{% endif %}

{% schema %}
{
  "name": "featured post",
  "class": "featured-post",
  "settings": [],
  "presets": [
    {
      "name": "featured post"
    }
  ]
}
{% endschema %}
